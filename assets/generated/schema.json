{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Goals",
  "type": "object",
  "description": "Set of goals available",
  "required": [
    "goals"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the goal"
    },
    "description": {
      "type": "string",
      "description": "Description of the set"
    },
    "goals": {
      "type": "array",
      "description": "List of goals added by this set",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "name",
          "condition"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Text to display for this goal"
          },
          "condition": {
            "description": "Condition to meet to complete this goal",
            "$ref": "#/definitions/conditions"
          }
        }
      }
    }
  },
  "definitions": {
    "conditions": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "action",
            "params"
          ],
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "has_completed_ending"
              ]
            },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "ending"
              ],
              "properties": {
                "ending": {
                  "type": "string",
                  "description": "Name of the ending to complete",
                  "enum": [
                    "weaver_queen",
                    "snared_silk",
                    "twisted_child",
                    "sister_of_the_void",
                    "passing_of_the_age"
                  ]
                }
              }
            }
          }
        },
        {
          "type": "object",
